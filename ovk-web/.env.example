# ovk-web environment configuration — copy to `.env.local` and edit.
# All client-exposed vars MUST be prefixed with VITE_ (Vite requirement).

# Root for every API call. Trailing slash is stripped.
# Default: "/api" (proxied to the Python backend via vite.config.ts).
# Set this to talk to a remote backend instead of the dev proxy:
#   VITE_API_BASE_URL=https://api.example.com/api
# VITE_API_BASE_URL=/api
