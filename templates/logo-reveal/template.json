{
  "id": "logo-reveal",
  "name": "Logo Reveal / End Card",
  "description": "Brand logo slides in with wordmark, tagline, and URL. Universal closer.",
  "duration": 5.0,
  "priority": 0,
  "mode": "slide-editor",
  "layouts": [
    {
      "id": "logo-card",
      "name": "Logo Card",
      "icon": "image",
      "fields": [
        {"id": "brand_name", "type": "text", "label": "Brand name", "default": "Acme"},
        {"id": "tagline", "type": "text", "label": "Tagline", "default": "Build anything"},
        {"id": "url", "type": "text", "label": "URL", "default": "acme.com"},
        {"id": "logo", "type": "image", "label": "Logo", "default": "assets/logo.svg"}
      ]
    }
  ],
  "default_slides": [
    {"layout": "logo-card", "brand_name": "Acme", "tagline": "Build anything", "url": "acme.com", "logo": "assets/logo.svg"}
  ],
  "slots": []
}
