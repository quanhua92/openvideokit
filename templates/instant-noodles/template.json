{
  "id": "instant-noodles",
  "name": "Instant Noodles Recipe",
  "description": "Step-by-step instant noodle cooking guide. Every step is customizable — swap text, brand, and product image.",
  "duration": 18.0,
  "priority": 0,
  "mode": "slide-editor",
  "layouts": [
    {
      "id": "noodle-step",
      "name": "Step",
      "icon": "list",
      "fields": [
        {"id": "step", "type": "text", "label": "Step number", "default": "1"},
        {"id": "product_image", "type": "image", "label": "Product image", "default": "assets/product.svg"},
        {"id": "brand_name", "type": "text", "label": "Brand / product name", "default": "Shin Ramyun"},
        {"id": "tagline", "type": "text", "label": "Tagline under the brand", "default": "Ready in 3 minutes"},
        {"id": "step_text", "type": "text", "label": "Step instruction", "default": "Boil 500ml of water"},
        {"id": "step_sub", "type": "text", "label": "Step sub-text", "default": "~2 minutes on high heat"}
      ]
    }
  ],
  "default_slides": [
    {"layout": "noodle-step", "step": "1", "product_image": "assets/product.svg", "brand_name": "Shin Ramyun", "tagline": "Ready in 3 minutes", "step_text": "Boil 500ml of water", "step_sub": "~2 minutes on high heat"},
    {"layout": "noodle-step", "step": "2", "product_image": "assets/product.svg", "brand_name": "Shin Ramyun", "tagline": "Ready in 3 minutes", "step_text": "Open the noodle packet", "step_sub": "Reserve the seasoning sachet"},
    {"layout": "noodle-step", "step": "3", "product_image": "assets/product.svg", "brand_name": "Shin Ramyun", "tagline": "Ready in 3 minutes", "step_text": "Add noodles to boiling water", "step_sub": "Stir gently to separate"},
    {"layout": "noodle-step", "step": "4", "product_image": "assets/product.svg", "brand_name": "Shin Ramyun", "tagline": "Ready in 3 minutes", "step_text": "Add the seasoning sachet", "step_sub": "Stir well to dissolve"},
    {"layout": "noodle-step", "step": "5", "product_image": "assets/product.svg", "brand_name": "Shin Ramyun", "tagline": "Ready in 3 minutes", "step_text": "Cook for 3 minutes", "step_sub": "Stir occasionally"},
    {"layout": "noodle-step", "step": "6", "product_image": "assets/product.svg", "brand_name": "Shin Ramyun", "tagline": "Ready in 3 minutes", "step_text": "Serve and enjoy!", "step_sub": "Top with egg, onions, or chili"}
  ],
  "slots": []
}
