{
  "id": "cli-tutorial",
  "name": "CLI Terminal Tutorial",
  "description": "3-step terminal install guide. Customize per-step commands and output. Edit the header (logo, product name, tagline) overlay directly in index.html.",
  "duration": 15.0,
  "priority": 0,
  "product_name": "MyDevTool",
  "tagline": "Ship faster with one command",
  "mode": "slide-editor",
  "layouts": [
    {
      "id": "terminal-step",
      "name": "Step",
      "icon": "terminal",
      "fields": [
        {"id": "step", "type": "text", "label": "Step number", "default": "1"},
        {"id": "headline", "type": "text", "label": "Headline", "default": "Install"},
        {"id": "command", "type": "text", "label": "Command (monospace)", "default": "npm install mydevtool"},
        {"id": "output", "type": "text", "label": "Output", "default": "✓ Added 42 packages in 3s"}
      ]
    }
  ],
  "default_slides": [
    {"layout": "terminal-step", "step": "1", "headline": "Install", "command": "npm install mydevtool", "output": "✓ Added 42 packages in 3s"},
    {"layout": "terminal-step", "step": "2", "headline": "Configure", "command": "mydevtool init", "output": "✓ Config created at .mydevtool"},
    {"layout": "terminal-step", "step": "3", "headline": "Deploy", "command": "mydevtool deploy", "output": "✓ Live at https://myapp.dev"}
  ],
  "slots": []
}
