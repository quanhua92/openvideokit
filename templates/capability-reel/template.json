  "default_slides": [
    {"layout": "reel-clip", "step": "01", "image": "assets/clip1.svg", "category": "Product Launch", "caption": "stripe.com"},
    {"layout": "reel-clip", "step": "02", "image": "assets/clip2.svg", "category": "Feature Showcase", "caption": "linear.app"},
    {"layout": "reel-clip", "step": "03", "image": "assets/clip3.svg", "category": "Brand Reel", "caption": "framer.com"}
  ],
